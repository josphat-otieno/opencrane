{
  "name": "@opencrane/server",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && prisma generate && esbuild src/index.ts src/scripts/migrate.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outdir=dist && cp -r src/reconcilers/tenants/deploy/workspace dist/workspace && tsx scripts/emit-openapi.mts",
    "emit-openapi": "tsx scripts/emit-openapi.mts",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.220.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@prisma/client": "^6.0.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.19.0",
    "http-proxy": "^1.18.1",
    "openapi-fetch": "^0.17.0",
    "pino": "^9.6.0",
    "pino-http": "^10.0.0",
    "prisma": "^6.0.0",
    "zod": "^3.25.0"
  },
  "optionalDependencies": {
    "@google-cloud/storage": "^7.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.19.0",
    "@types/http-proxy": "^1.17.14",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "openid-client": "^6.8.4",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.8"
  },
  "nx": {
    "name": "opencrane",
    "tags": [
      "scope:app"
    ],
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist",
          "{workspaceRoot}/dist/apps/opencrane/openapi.json"
        ]
      },
      "emit-openapi": {
        "outputs": [
          "{workspaceRoot}/dist/apps/opencrane/openapi.json"
        ]
      }
    }
  },
  "prisma": {
    "schema": "prisma/schema"
  }
}
