{
  "name": "contracts",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/contracts/src",
  "tags": [
    "scope:shared"
  ],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.json --noEmit",
        "cwd": "libs/contracts"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests",
        "cwd": "libs/contracts"
      }
    },
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npm run emit-openapi -w @opencrane/server",
          "openapi-typescript ../../dist/apps/opencrane/openapi.json -o src/generated/api.ts"
        ],
        "cwd": "libs/contracts",
        "parallel": false
      }
    }
  }
}
