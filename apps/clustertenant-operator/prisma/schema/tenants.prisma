model Tenant {
  name               String                    @id
  displayName        String                    @map("display_name")
  email              String
  team               String?
  phase              String                    @default("Pending")
  ingressHost        String?                   @map("ingress_host")
  clusterTenantRef   String?                   @map("cluster_tenant_ref")
  /// IdP-verified subject (OIDC `sub`) of the user this workspace belongs to. The
  /// openclaw Tenant is 1:1 with a ClusterTenant user; binding the subject (not just
  /// the contact `email`) is what lets the contract compiler inherit that user's
  /// rights (S4). Nullable for legacy/imported tenants created before the binding.
  subject            String?
  configOverrides    Json?                     @map("config_overrides")
  awarenessWave      String?                   @map("awareness_wave")
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")
  auditEntries       AuditEntry[]
  litellmKeys        TenantLiteLlmKey[]
  datasetMemberships TenantDatasetMembership[]
  brokeredDevices    BrokeredDevice[]
  workspaceDocs      TenantWorkspaceDoc[]
  docMergeProposals  DocMergeProposal[]
  participationEvents ParticipationEvent[]
  participation      TenantParticipation?

  @@map("tenants")
}
