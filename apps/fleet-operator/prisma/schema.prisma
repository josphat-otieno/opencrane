// fleet-manager registry schema (Stage 3 — ADR 0002 / silo split).
//
// fleet-manager is the cluster-wide singleton that manages the FLEET of ClusterTenants.
// This is its OWN database — the global registry — distinct from each silo's per-CT DB
// (which clustertenant-manager owns). The registry holds the cross-silo records: the
// ClusterTenant catalogue (+ its provisioned Zitadel identifiers), billing accounts, and
// org memberships. Per-silo tenant data (Tenant, grants, datasets, …) lives in the silo DBs.
//
// NOTE: the client is generated to a PACKAGE-LOCAL output. The monorepo already has a
// second Prisma schema (clustertenant-manager) that generates the default `@prisma/client`;
// two schemas generating to the same target would clobber each other, so this one emits an
// isolated client under src/generated/prisma and is imported from there.
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClusterTenantIsolationTier {
  Shared           @map("shared")
  DedicatedNodes   @map("dedicatedNodes")
  DedicatedCluster @map("dedicatedCluster")
}

enum ClusterTenantComputeMode {
  Shared    @map("shared")
  Dedicated @map("dedicated")
}

enum OrgRole {
  Owner  @map("owner")
  Admin  @map("admin")
  Member @map("member")
}

enum OrgMemberStatus {
  Active    @map("active")
  Suspended @map("suspended")
}

model ClusterTenant {
  /// Stable cluster-scoped identifier (the customer key).
  name           String                     @id
  /// Human-readable customer name.
  displayName    String                     @map("display_name")
  /// Optional customer-vanity domain CNAMEd onto the org's canonical apex; an overlay, not the org identity. Unique (NULLs distinct) so a vanity host resolves to exactly one org for per-org login.
  vanityDomain   String?                    @unique @map("vanity_domain")
  /// Isolation strength chosen for this customer.
  isolationTier  ClusterTenantIsolationTier @default(Shared) @map("isolation_tier")
  /// Whether the customer shares nodes or gets a dedicated pool.
  computeMode    ClusterTenantComputeMode   @default(Shared) @map("compute_mode")
  /// Dedicated node pool name; set when computeMode is Dedicated.
  nodePool       String?                    @map("node_pool")
  /// Aggregate resource ceiling ({cpu,memory,pods,storage,gpu}).
  quota          Json?
  /// Maximum org memberships (seats) allowed. Null = uncapped. The fleet is the seat
  /// authority (seats are ordered centrally); member-create paths refuse a new seat once
  /// the org is at its cap. Standalone silos never reach the fleet and are always uncapped.
  seatCap        Int?                       @map("seat_cap")
  /// Current lifecycle phase (pending|provisioning|ready|failed).
  phase          String                     @default("pending")
  /// Human-readable detail, set on failure or transitional states.
  message        String?
  /// Namespace bound to this customer once provisioned.
  boundNamespace String?                    @map("bound_namespace")
  /// Identifier of the provisioner that owns this customer's boundary.
  provisioner    String?
  /// Zitadel Organization id provisioned for this org's isolated user pool. Null until provisioned.
  zitadelOrgId       String?                @map("zitadel_org_id")
  /// Zitadel OIDC application id for this org's login surface at `<org>.<base>`.
  zitadelAppId       String?                @map("zitadel_app_id")
  /// OIDC client_id of this org's Zitadel app — the per-org credential login uses. Null until provisioned.
  zitadelClientId    String?                @map("zitadel_client_id")
  /// The redirect URI registered on this org's Zitadel app.
  zitadelRedirectUri String?                @map("zitadel_redirect_uri")
  /// Zitadel project id of this org's `opencrane` project (the redirect-URI update endpoint is project-scoped). Null until provisioned.
  zitadelProjectId   String?                @map("zitadel_project_id")
  /// Creation timestamp.
  createdAt      DateTime                   @default(now()) @map("created_at")
  /// Last update timestamp.
  updatedAt      DateTime                   @updatedAt @map("updated_at")
  /// Membership rows binding subjects to this org with a role; cascades on delete.
  memberships    OrgMembership[]

  @@map("cluster_tenants")
}

model BillingAccount {
  /// Surrogate key.
  id          String   @id @default(cuid())
  /// IdP-verified subject (OIDC `sub`) that owns this billing account; unique.
  subject     String   @unique
  /// The caller's IdP-verified email at create time (for human reconciliation; not the key).
  email       String?
  /// Optional human-readable billing name (company / individual).
  displayName String?  @map("display_name")
  /// Creation timestamp.
  createdAt   DateTime @default(now()) @map("created_at")
  /// Last update timestamp.
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([subject])
  @@map("billing_accounts")
}

model OrgMembership {
  /// Surrogate key.
  id            String        @id @default(cuid())
  /// Organisation (ClusterTenant) this membership is in.
  clusterTenant String        @map("cluster_tenant")
  /// IdP-verified subject (OIDC `sub`) holding the membership.
  subject       String
  /// Role held within the organisation.
  role          OrgRole
  /// Lifecycle status. A Suspended member is disabled in the org (blocked at the IdP, sessions/devices cut, pod suspended) and FREES their seat — seat caps count only Active memberships.
  status        OrgMemberStatus @default(Active) @map("status")
  /// Creation timestamp.
  createdAt     DateTime      @default(now()) @map("created_at")
  /// Last update timestamp.
  updatedAt     DateTime      @updatedAt @map("updated_at")
  /// Owning organisation; cascades on org delete so memberships never linger.
  org           ClusterTenant @relation(fields: [clusterTenant], references: [name], onDelete: Cascade)

  @@unique([clusterTenant, subject])
  @@index([subject])
  @@index([clusterTenant])
  @@map("org_memberships")
}
