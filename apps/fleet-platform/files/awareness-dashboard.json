{
  "uid": "opencrane-awareness-slo",
  "title": "OpenCrane — Fleet Awareness SLOs",
  "tags": ["opencrane", "awareness"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Policy violations (SLO: 0)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "targets": [ { "expr": "opencrane_awareness_policy_violations_total", "legendFormat": "violations" } ]
    },
    {
      "id": 2,
      "title": "Version drift",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 } ] } } },
      "targets": [ { "expr": "opencrane_awareness_drifted_total", "legendFormat": "drifted" } ]
    },
    {
      "id": 3,
      "title": "Participation",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "opencrane_awareness_participating_total", "legendFormat": "participating" },
        { "expr": "opencrane_awareness_non_participating_total", "legendFormat": "non-participating" }
      ]
    },
    {
      "id": 4,
      "title": "Rollout frontier (promoted waves)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [ { "expr": "opencrane_awareness_rollout_promoted_waves", "legendFormat": "promoted waves" } ]
    },
    {
      "id": 5,
      "title": "Tenants by severity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [ { "expr": "opencrane_awareness_tenants_by_severity", "legendFormat": "{{severity}}" } ]
    },
    {
      "id": 6,
      "title": "Fleet size vs participating",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "opencrane_awareness_tenants_total", "legendFormat": "total" },
        { "expr": "opencrane_awareness_participating_total", "legendFormat": "participating" }
      ]
    }
  ]
}
