{
  "name": "opencrane-platform",
  "version": "0.6.2",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "description": "Multi-tenant OpenClaw platform on Kubernetes",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run db:generate -w @opencrane/clustertenant-operator && nx run-many -t build",
    "dev": "nx run-many -t dev --parallel=10",
    "test": "nx run-many -t test",
    "test:e2e:k3d": "./libs/k8s-platform/tests/k3d-e2e.sh",
    "test:phase1": "nx run clustertenant-operator:test && ./libs/k8s-platform/tests/k3d-e2e.sh",
    "install:phase1:local": "KEEP_CLUSTER=1 ./libs/k8s-platform/tests/k3d-local.sh",
    "lint": "nx run-many -t lint",
    "lint:boundaries": "eslint .",
    "docs:sync-openapi": "npm run sync-openapi -w website",
    "docs:dev": "npm run dev -w website",
    "docs:build": "npm run build -w website",
    "docs:preview": "npm run preview -w website",
    "docker:build:tenant": "docker build -f apps/tenant/deploy/Dockerfile -t ghcr.io/italanta/opencrane-tenant:latest .",
    "docker:build:control-plane": "docker build -f apps/clustertenant-operator/deploy/Dockerfile -t ghcr.io/italanta/opencrane-clustertenant-manager:latest .",
    "docker:build:docs": "docker build -f website/Dockerfile -t ghcr.io/italanta/docs:latest .",
    "build:control-plane-ui": "nx build control-plane",
    "serve:control-plane-ui": "nx serve control-plane"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@nx/angular": "^23.0.2",
    "@nx/eslint-plugin": "^23.0.2",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "esbuild": "^0.25.0",
    "eslint": "^10.7.0",
    "express-session": "^1.19.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.1",
    "nx": "^23.0.2",
    "openapi-typescript": "^7.13.0",
    "supertest": "^7.0.0",
    "typescript": "^5.9.2",
    "vite-tsconfig-paths": "^5.1.0",
    "vitest": "^3.1.0"
  },
  "workspaces": [
    "apps/*",
    "website"
  ],
  "dependencies": {
    "@a2ui/angular": "0.10.2",
    "@a2ui/web_core": "0.10.3",
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@kubernetes/client-node": "^1.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.57.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@primeng/themes": "^21.0.0",
    "@prisma/client": "^6.0.0",
    "@sinclair/typebox": "0.34.49",
    "dompurify": "^3.4.11",
    "express": "^5.1.0",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.19.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "openapi-fetch": "^0.17.0",
    "openid-client": "^6.8.4",
    "pino": "^9.6.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.0"
  }
}
