{
  "name": "opencrane-platform",
  "version": "0.5.3",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "description": "Multi-tenant OpenClaw platform on Kubernetes",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "esbuild"
    ],
    "ignoredBuiltDependencies": []
  },
  "scripts": {
    "build": "pnpm --filter @opencrane/clustertenant-platform db:generate && pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "test:e2e:k3d": "./platform/tests/k3d-e2e.sh",
    "test:phase1": "pnpm --filter @opencrane/fleet-platform test && pnpm --filter @opencrane/clustertenant-platform test && ./platform/tests/k3d-e2e.sh",
    "install:phase1:local": "./platform/install.sh local --keep-cluster",
    "install:phase1:gcp": "./platform/install.sh gcp",
    "wizard": "./platform/wizard.sh",
    "lint": "pnpm -r lint",
    "docs:sync-openapi": "pnpm --filter @opencrane/website sync-openapi",
    "docs:dev": "pnpm --filter @opencrane/website dev",
    "docs:build": "pnpm --filter @opencrane/website build",
    "docs:preview": "pnpm --filter @opencrane/website preview",
    "docker:build:tenant": "docker build -f apps/tenant/deploy/Dockerfile -t ghcr.io/italanta/opencrane-tenant:latest .",
    "docker:build:operator": "docker build -f apps/fleet-platform/deploy/Dockerfile -t ghcr.io/italanta/opencrane-fleet-manager:latest .",
    "docker:build:control-plane": "docker build -f apps/clustertenant-platform/deploy/Dockerfile -t ghcr.io/italanta/opencrane-clustertenant-manager:latest .",
    "docker:build:docs": "docker build -f website/Dockerfile -t ghcr.io/italanta/docs:latest ."
  }
}
