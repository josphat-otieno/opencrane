model OrgDocument {
  id                  String   @id @default(cuid())
  source              String
  sourceId            String   @map("source_id")
  owner               String
  teamScope           String?  @map("team_scope")
  departmentScope     String?  @map("department_scope")
  projectScope        String?  @map("project_scope")
  sensitivityTags     String[] @map("sensitivity_tags")
  title               String?
  content             String
  contentHash         String?  @map("content_hash")
  confidentiality     String?
  jurisdiction        String?
  retentionClass      String?  @map("retention_class")
  aclOrigin           String   @map("acl_origin")
  sourceUpdatedAt     DateTime @map("source_updated_at")
  freshnessRecordedAt DateTime @map("freshness_recorded_at")
  ingestCursor        String   @map("ingest_cursor")
  embeddingReady      Boolean  @default(false) @map("embedding_ready")
  ingestedAt          DateTime @default(now()) @map("ingested_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([source, sourceId])
  @@index([source])
  @@index([owner])
  @@index([teamScope])
  @@map("org_documents")
}

model HarvestingCursor {
  id          String   @id @default(cuid())
  source      String   @unique
  cursorValue String   @map("cursor_value")
  lastSyncAt  DateTime @map("last_sync_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("harvesting_cursors")
}

/// Fleet-wide awareness contract rollout state (P4B.3). Singleton (`id="default"`).
///
/// Promotes a `targetVersion` across tenant-cohort canary waves
/// (personal→project→department→org) while un-promoted waves stay on
/// `stableVersion` — no fleet downtime. `promotedWaves` is the advancing
/// frontier; clearing it is the one-step rollback. A tenant's wave is
/// `Tenant.awarenessWave` (null → the final/most-conservative wave).
model AwarenessRollout {
  /// Singleton key.
  id            String   @id @default("default")
  /// The contract version being rolled out to promoted waves.
  targetVersion String   @map("target_version")
  /// The contract version un-promoted waves continue to run.
  stableVersion String   @map("stable_version")
  /// Ordered canary waves (narrow→wide); JSON string array.
  waves         Json
  /// Waves promoted to `targetVersion` so far; JSON string array (the frontier).
  promotedWaves Json     @map("promoted_waves")
  /// When true, promoted waves compute the target but still serve stable (shadow).
  shadowMode    Boolean  @default(false) @map("shadow_mode")
  /// When the rollout was created.
  createdAt     DateTime @default(now()) @map("created_at")
  /// When the rollout was last changed (promote/rollback/redefine).
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("awareness_rollouts")
}

/// Kind of fleet participation event a claw emits over the control-plane API (P4B.5).
enum ParticipationEventKind {
  /// A2A-style capability advertisement (the claw's Agent Card).
  AgentCard       @map("agent_card")
  /// A skill execution outcome (ok or policy-violation).
  SkillExecution  @map("skill_execution")
  /// Liveness/participation ping carrying the running contract version.
  Heartbeat       @map("heartbeat")
}

/// A fleet participation event from a claw (P4B.5). Transport is the control-plane
/// API with at-least-once + idempotency keys (no new bus) — `(tenant, idempotencyKey)`
/// is unique so a redelivered event is recorded once.
model ParticipationEvent {
  /// Surrogate key.
  id             String                 @id @default(cuid())
  /// Emitting tenant.
  tenant         String
  /// Event kind.
  kind           ParticipationEventKind
  /// Caller-supplied idempotency key for at-least-once dedup.
  idempotencyKey String                 @map("idempotency_key")
  /// For SkillExecution: `ok` or `policy-violation`.
  outcome        String?
  /// Kind-specific payload (e.g. the Agent Card manifest, skill digest/name).
  payload        Json?
  /// When the event occurred (claw clock).
  occurredAt     DateTime               @map("occurred_at")
  /// When the control plane recorded it.
  createdAt      DateTime               @default(now()) @map("created_at")
  /// Owning tenant; cascades on tenant delete.
  tenantRef      Tenant                 @relation(fields: [tenant], references: [name], onDelete: Cascade)

  @@unique([tenant, idempotencyKey])
  @@index([tenant])
  @@map("participation_events")
}

/// Per-tenant participation rollup the control plane monitors (P4B.5): liveness,
/// the running awareness contract version (for drift detection vs the rollout),
/// the latest Agent Card, and skill-execution / policy-violation counters.
model TenantParticipation {
  /// Tenant (one rollup per tenant).
  tenant                 String   @id
  /// Most recent event time seen from this tenant.
  lastSeenAt             DateTime @map("last_seen_at")
  /// The awareness contract version the tenant reports running (drift signal).
  runningContractVersion String?  @map("running_contract_version")
  /// The latest advertised Agent Card manifest.
  agentCard              Json?    @map("agent_card")
  /// Total skill executions reported.
  skillExecutionCount    Int      @default(0) @map("skill_execution_count")
  /// Total policy-violating skill executions reported (critical signal).
  policyViolationCount   Int      @default(0) @map("policy_violation_count")
  /// When the rollup was last updated.
  updatedAt              DateTime @updatedAt @map("updated_at")
  /// Owning tenant; cascades on tenant delete.
  tenantRef              Tenant   @relation(fields: [tenant], references: [name], onDelete: Cascade)

  @@map("tenant_participation")
}
