model AccessPolicy {
  name           String   @id
  description    String?
  tenantSelector Json?    @map("tenant_selector")
  domains        Json?
  egressRules    Json?    @map("egress_rules")
  mcpServers     Json?    @map("mcp_servers")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("access_policies")
}
