{
  "name": "@opencrane/fleet-operator",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && prisma generate && esbuild src/index.ts src/scripts/migrate.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outdir=dist && mkdir -p dist/generated && cp -r src/generated/prisma dist/generated/prisma && tsx scripts/emit-openapi.mts",
    "emit-openapi": "tsx scripts/emit-openapi.mts",
    "db:generate": "prisma generate",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.56.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.57.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@prisma/client": "^6.0.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.19.0",
    "openapi-fetch": "^0.17.0",
    "openid-client": "^6.8.4",
    "pino": "^9.6.0",
    "prisma": "^6.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "nx": {
    "tags": [
      "scope:app"
    ]
  }
}
